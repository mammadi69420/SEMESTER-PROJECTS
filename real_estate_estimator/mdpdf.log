   DEBUG: 2026-04-12 21:59:32,542:      pdf_renderer.py:  470: printSegment: Corner Plot
   DEBUG: 2026-04-12 21:59:32,543:      pdf_renderer.py:  470: printSegment: "
   DEBUG: 2026-04-12 21:59:32,543:      pdf_renderer.py:  470: printSegment: , 
   DEBUG: 2026-04-12 21:59:32,544:      pdf_renderer.py:  470: printSegment: "
   DEBUG: 2026-04-12 21:59:32,544:      pdf_renderer.py:  470: printSegment: Park Facing
   DEBUG: 2026-04-12 21:59:32,545:      pdf_renderer.py:  470: printSegment: "
   DEBUG: 2026-04-12 21:59:32,545:      pdf_renderer.py:  470: printSegment: , or 
