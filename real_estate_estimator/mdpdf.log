   DEBUG: 2026-04-12 21:59:32,323:      pdf_renderer.py:  470: printSegment: , 
   DEBUG: 2026-04-12 21:59:32,324:      pdf_renderer.py:  470: printSegment: ColumnTransformer
   DEBUG: 2026-04-12 21:59:32,324:      pdf_renderer.py:  470: printSegment: , 
